PORT=8080

MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
JWT_PURPOSE_SECRET=change_me_purpose

INVITE_TOKEN_TTL=48h
VERIFY_EMAIL_TOKEN_TTL=24h
VERIFY_PIN_TOKEN_TTL=15m
VERIFY_PIN_MAX_ATTEMPTS=3
RESET_PASSWORD_TOKEN_TTL=30m

# Comma-separated trusted origins for browser clients
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cookie settings
AUTH_COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

APP_BASE_URL=http://localhost:5173
# Base backend URL used by callbacks and links
# Preferred: no /api suffix (e.g. http://localhost:8080 or https://api.your-domain.com)
# Compatible: if BASE_URL already ends with /api, callback resolution still works.
BASE_URL=http://localhost:8080

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@example.com

# SaaS onboarding and pricing
SAAS_TRIAL_DAYS=14

# Paystack test-mode billing configuration
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:5500/api/saas/paystack/callback
PAYSTACK_WEBHOOK_URL=http://localhost:5500/api/saas/paystack/webhook

# Cloudinary settings for image uploads
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_URL=

# Encryption key for sensitive data (any length; derived to 32 bytes via SHA-256)
ENCRYPTION_KEY=change_me_to_a_strong_secret

# Default password assigned to staff members imported via CSV
STAFF_IMPORT_DEFAULT_PASSWORD=ChangeMe123!

# Seeding Admin user details (used on first boot to create the owner account)
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_ORG_NAME=
ADMIN_SAAS_PLAN=free

# Seeding Admin email settings — set SEED_ADMIN_EMAIL_SETTINGS=true to apply on first boot
SEED_ADMIN_EMAIL_SETTINGS=false
SEED_ADMIN_SMTP_HOST=
SEED_ADMIN_SMTP_PORT=587
SEED_ADMIN_SMTP_SECURE=false
SEED_ADMIN_SMTP_USER=
SEED_ADMIN_SMTP_FROM_EMAIL=
SEED_ADMIN_SMTP_FROM_NAME=
SEED_ADMIN_SMTP_PASS=

# Seeding Admin branding settings — set SEED_ADMIN_BRANDING=true to apply on first boot
SEED_ADMIN_BRANDING=false
SEED_ADMIN_BRAND_PRIMARY_COLOR=
SEED_ADMIN_BRAND_SECONDARY_COLOR=
SEED_ADMIN_BRAND_ACCENT_COLOR=

# Keep dangerous maintenance endpoints disabled by default
ALLOW_DESTRUCTIVE_ROUTES=false

# Upstash QStash connection settings
QSTASH_URL="https://qstash-eu-central-1.upstash.io"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# QStash dispatch endpoint and shared auth token
# Optional: leave empty to auto-build from BASE_URL as ${BASE_URL}/email-jobs/dispatch
# You can still set this explicitly for custom routing or a separate callback domain.
QSTASH_EMAIL_DISPATCH_URL="/api/email-jobs/dispatch"
EMAIL_JOB_DISPATCH_TOKEN="change_me"

# QStash publish retries
EMAIL_JOB_ATTEMPTS=3

BASE_URL=http://localhost:5500
